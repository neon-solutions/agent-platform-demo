# ── Control-plane Neon Postgres (Better Auth + Drizzle source of truth) ──
# Pooled connection string for the control-plane project's main branch.
DATABASE_URL=

# ── Better Auth ──
# 32+ char random secret. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public base URL of the control app (used as JWT issuer/audience + auth base).
BETTER_AUTH_URL=http://localhost:3040
NEXT_PUBLIC_APP_URL=http://localhost:3040

# ── Neon control plane (@neon/sdk) ──
# Org-scoped API keys. The control key manages the control project (snapshots
# of tenant DBs are done with the per-tenant org keys below).
NEON_CONTROL_API_KEY=
NEON_CONTROL_ORG_ID=org-summer-dust-66593634
NEON_CONTROL_PROJECT_ID=

# ── Tenant Neon orgs (the databases behind every vibe-coded app) ──
NEON_FREE_ORG_ID=org-icy-cherry-28389432
NEON_FREE_API_KEY=
NEON_PAID_ORG_ID=org-square-meadow-60455149
NEON_PAID_API_KEY=

# ── Vercel Sandboxes (build & serve the vibe-coded apps) ──
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# ── Neon Function coding agent (Mastra) ──
# Public invocation URL of the deployed agent function. The browser calls this
# directly with a short-lived Bearer JWT minted by the control app.
NEXT_PUBLIC_AGENT_URL=
