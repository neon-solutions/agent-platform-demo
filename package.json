{
  "name": "vibe",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "typescript": "^6",
      "@types/node": "^22.13.14",
      "lucide-react": "^1.23.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "sonner": "^2.0.7",
      "tailwindcss": "^4.3.2",
      "@orpc/server": "^1.14.6",
      "@orpc/client": "^1.14.6",
      "@orpc/openapi": "^1.14.6",
      "@orpc/zod": "^1.14.6",
      "better-auth": "1.6.23",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=.env run --filter '*' dev",
    "build": "bun --env-file=.env run --filter '*' build",
    "check-types": "bun --env-file=.env run --filter '*' check-types",
    "dev:web": "bun --env-file=.env run --filter web dev",
    "db:push": "bun run --filter @vibe/db db:push",
    "db:studio": "bun run --filter @vibe/db db:studio",
    "db:generate": "bun run --filter @vibe/db db:generate",
    "db:migrate": "bun run --filter @vibe/db db:migrate",
    "deploy:setup": "vercel link",
    "dev:vercel": "vercel dev -L",
    "env:preview": "tsx scripts/sync-vercel-env.ts preview",
    "env:production": "tsx scripts/sync-vercel-env.ts production",
    "deploy": "vercel deploy",
    "deploy:prod": "vercel deploy --prod",
    "deploy:check": "vercel deploy --dry",
    "check": "oxlint && oxfmt --write",
    "agent:dev": "bun run --filter @vibe/agent dev",
    "agent:deploy": "bun run --filter @vibe/agent deploy"
  },
  "dependencies": {
    "@vibe/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vibe/config": "workspace:*",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "tsx": "^4.22.5",
    "typescript": "catalog:",
    "vercel": "^54.18.6"
  },
  "packageManager": "bun@1.3.6"
}
